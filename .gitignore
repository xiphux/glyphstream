node_modules

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Local config + state
config.toml
# Whitelist test fixtures — they live under tests/ and are required for
# CI runs. Without this exception, the rule above silently blocks them.
!tests/**/config.toml
# Same for the README-screenshot pipeline's demo config.
!scripts/screenshots/config.toml
data/


# Bundle analyzer output
bundle-stats.html

# esbuild-bundled code-interpreter worker. Rebuilt by `pnpm build:worker`,
# which runs as a pre-step of both `pnpm dev` and `pnpm build` — never
# commit the bundled output. The .ts source is the canonical version.
src/lib/server/code-interpreter/worker.js

# E2E test data + Playwright outputs
tests/.e2e-data/
playwright-report/
# Generated at e2e setup when Foundry allocates a non-default MOCK_UPSTREAM_PORT
# (playwright.config.ts rewrites the fixture's mock base_url into this sibling).
tests/e2e/fixtures/config.generated.toml
test-results/
.playwright-cli/

# OWUI export files — used as opt-in fixtures by the import test suite,
# but they contain personal chat history and should never be committed.
/chat-export*.json
/text-chat*.json
/image-chat*.json
/imports/
scripts/screenshots/.demo-data/

# OpenCode deepwork session state — local progress notes, never committed
.slim/deepwork/
