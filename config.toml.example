# GlyphStream — endpoint configuration
#
# Each [[endpoints]] block defines an OpenAI-compatible HTTP upstream the app
# can route requests to. Models from every endpoint are aggregated into one
# unified picker, with model IDs internally namespaced as
# "{endpoint_id}::{upstream_model_id}".
#
# Secrets convention: any field whose name ends in `_env` is the *name* of an
# env var to read at startup, never the literal secret. Keeps this file safe
# to commit to a private repo.

# ── Optional: task_model ─────────────────────────────────────────────
# The small utility model for lightweight background text tasks. Today it
# (1) auto-generates conversation titles — after the first user+assistant
# exchange in a new chat, GlyphStream calls it once to produce a short
# title, replacing the default first-N-chars-of-prompt preview — and
# (2) backfills topic labels for saved memories created before memories
# carried a topic (a one-time sweep; new memories are labelled at save time).
#
# `model` is "endpoint_id::upstream_model_id" — the same namespaced shape
# the model picker uses. The endpoint it names is one defined further
# down this file; forward references are fine (the id is resolved at
# request time, not parse time). Pick a small, fast model: title
# delivery has a 5s SSE budget so it lands while the user is still
# watching the message finish. Slower models still run — the title just
# appears on the next sidebar refetch. Unset / typo'd / removed-endpoint
# is non-fatal: titling silently falls back to the first-N-chars preview.
#
# `private` (default false): whether this task model is trusted with the
# content of a "Private chat". Titling sends the chat's first exchange to
# the task model — a secondary model unrelated to the chat's own — so a
# Private chat is auto-titled ONLY when this is true. Set it only if the
# task model runs somewhere you trust with private content (e.g. a local
# llama.cpp); left false, Private chats keep their local first-line title.
#
# Configured as a [table] header, so it can sit anywhere in the file (unlike a
# bare top-level key, which TOML binds to the nearest table above it).
# [task_model]
# model = "groq::llama-3.1-8b-instant"
# private = false
#
# The older bare-string form is still accepted (equivalent to private = false):
# task_model = "groq::llama-3.1-8b-instant"   # MUST sit above every [table] header

# ── Optional: [tools] ────────────────────────────────────────────────
# max_tool_loop_iterations — the hard cap on upstream round-trips within a
# single turn's tool loop (a runaway-tool_calls backstop, not a normal limit).
# Default 8. Raise it if you use many high-tool-count or deferred (defer_tools)
# servers and complex turns hit the cap; lower it to bound worst-case latency on
# a small local model. Hitting the cap surfaces a visible error, not silent
# truncation. (As a table header, this must sit ABOVE every [[endpoints]] block,
# like [search]/[embeddings] below.)
# [tools]
# max_tool_loop_iterations = 8

# ── Optional: [image_enhancement] ────────────────────────────────────
# Rewrites image AND video prompts into the target model's preferred format
# (image: natural-language, booru tags, keyword soup, hybrid, json; video:
# cinematic-prose, structured-cinematic) before generating — and expands them
# when they're vague. One block + one enhancer LLM drives both media (it keeps
# its historical name). Off when this block is absent (prompts pass through
# verbatim); non-fatal if the model errors. Runs per generation (each fan-out
# branch enhances for its own model), is skipped for image-to-image and
# image-to-video, and is toggleable per-conversation. Pick a CAPABLE model —
# this is a separate slot from the small `task_model`. Which model wants which
# style is set per-model via [endpoints.model_prompt_styles] (below) or the
# bridge's meta.json. See docs/configuration.md#prompt-enhancement-image_enhancement.
# (Top-level block — like [tools], must sit ABOVE every [[endpoints]] block.)
# [image_enhancement]
# model = "groq::llama-3.3-70b-versatile"   # endpoint_id::upstream_model_id
# max_tokens = 1000                          # cap per rewrite (default fits a JSON prompt)
# temperature = 0.7
# [image_enhancement.style_instructions]    # optional: override built-in wording
#   "booru-tags" = "Write strictly comma-separated Danbooru tags ..."

# ── Optional: [memory_model] ─────────────────────────────────────────
# The capable model for the background memory-consolidation ("dreaming") pass:
# it periodically tidies each user's saved memories — merging duplicates, folding
# superseded facts into a current+previous phrasing, distilling stale notes to
# their durable residue, and (last resort) pruning. Off when this block is absent.
# Pick a CAPABLE model (a separate slot from the small `task_model`): merging
# facts without dropping them is not a job for a weak model. Removals are
# soft-deleted (recoverable for a retention window), never hard-deleted.
#
# Runs on the GPU, so schedule it out of the way: `active_hours` restricts it to a
# quiet window (24-hour, interpreted in `timezone`; overnight ranges like
# "22:00-06:00" are fine), and it also queues behind live chats on the endpoint.
# See docs/configuration.md#memory-consolidation-memory_model.
# (Top-level block — like [tools], must sit ABOVE every [[endpoints]] block.)
# The same model also writes the per-conversation summaries and the
# conversation-topics map that powers `search_conversations`.
# [memory_model]
# model = "dirac::qwen3-32b"          # endpoint_id::upstream_model_id
# max_tokens = 2000                    # cap per consolidation call
# temperature = 0.2                    # low — careful bookkeeping, not creative writing
# active_hours = "02:00-06:00"         # optional; omit to run any time
# timezone = "America/New_York"        # optional; default "UTC"
# overview_max_chars = 2500            # optional; size of the conversation-topics map.
#                                      # It rides in the system prompt on EVERY
#                                      # personalization-on turn, so this is a recurring
#                                      # per-message token cost (~2500 chars ≈ ~600
#                                      # tokens), not a one-off. It's a signpost telling
#                                      # the model which past threads exist to search —
#                                      # not a log of them — so it needs about a line per
#                                      # theme, and themes grow far slower than
#                                      # conversations do. Raise it only if the map
#                                      # actually goes thin.

# Example: an openai-api-bridge instance running on the NAS — gives us
# ComfyUI image/video, Venice, plus any openai-compat passthrough providers
# the bridge fronts (e.g. local llama-server) under one endpoint.
# [[endpoints]]
# id = "nas-bridge"
# display_name = "NAS Bridge"
# base_url = "http://192.168.1.10:8080/v1"
# api_key_env = "NAS_BRIDGE_KEY"
# request_timeout_seconds = 600
# # An aggregating proxy like the bridge usually exposes many real providers
# # (openrouter, venice, imagerouter, comfyui...) under one endpoint. Setting
# # group_by="owned_by" buckets the model picker by the upstream's `owned_by`
# # field instead of bundling everything under one "NAS Bridge" group. Models
# # that don't report owned_by fall back to the endpoint's display_name.
# group_by = "owned_by"

# Example: a local llama-server speaking openai compat directly (no bridge
# in front). Useful when you have a chat-only backend with no images/videos
# and don't want a bridge instance just to combine endpoints.
# [[endpoints]]
# id = "llama-main"
# display_name = "Llama (main)"
# base_url = "http://192.168.1.20:8080/v1"
# # api_key_env omitted -> no Authorization header sent

# Example: a hosted openai-compatible provider.
# [[endpoints]]
# id = "groq"
# display_name = "Groq"
# base_url = "https://api.groq.com/openai/v1"
# api_key_env = "GROQ_API_KEY"
# request_timeout_seconds = 120

# Optional: tell GlyphStream which provider quirk to apply to streaming
# responses from this endpoint. If omitted, GlyphStream auto-detects from
# upstream model id substrings; default is `passthrough`.
# Valid values: passthrough | deepseek-r1 | openai-o-series | openrouter
# provider_quirk = "deepseek-r1"

# Optional: how the model picker labels the group an endpoint's models
# appear under.
# - "endpoint" (default): one group per [[endpoints]] block, labeled with
#   `display_name`. Right for direct upstreams (Groq, llama-server, OpenAI).
# - "owned_by": bucket each model by its `owned_by` field. Useful for
#   aggregating proxies (openai-api-bridge) that fan out into many real
#   providers. Models without `owned_by` fall back to the endpoint's group.
# group_by = "owned_by"

# Optional: enable native OpenAI tool calling for this endpoint. When true,
# GlyphStream forwards the registered `tools` array on chat requests and
# runs the model's tool_calls server-side, looping until the model returns
# a final text response. See the README's "Tool calling" section for the
# full setup (model requirements, llama-server --jinja flag).
# Defaults to false — endpoints stay tool-disabled until opted in.
#
# When the upstream advertises tool support per model (the openai-api-bridge
# does this for OpenRouter via the `supported_parameters` field), that
# per-model signal wins and this flag is the fallback for models that don't
# self-report.
# supports_tools = true

# Optional: cap how many generations run against this endpoint at once.
# Extra requests queue (FIFO) and stream a "queued" state to the client
# until a slot frees. The slot is held for the WHOLE generation.
# Defaults to 4 when omitted — a friendly cap so a large multi-model
# fan-out trickles instead of blasting the upstream all at once.
#  - Set to 1 for a single-GPU local backend (llama-server, ComfyUI bridge)
#    that can only hold one model in VRAM, so requests serialize instead of
#    thrashing.
#  - Raise it (up to 1024) for a hosted provider that handles its own
#    concurrency and you want more parallelism.
# max_concurrent = 1

# Optional: the model's context-window size, in tokens. Powers the
# "27,725 / 40,960 tokens" budget readout in the chat header (and, later,
# compaction). The OpenAI /v1/models row has no context-size field, so when
# the upstream surfaces one per model — llama.cpp's `n_ctx` (a loaded model)
# or router `--ctx-size`, vLLM's `max_model_len`, or a bridge-normalized
# `context_window` — GlyphStream uses that automatically and you can leave
# this unset. Set it as a blanket fallback for endpoints that advertise
# nothing (raw OpenAI, Groq, …); the per-model upstream value still wins
# when present. Omit for "unknown" (the header then shows just the running
# token count, no ceiling).
# context_window = 32768

# Optional: per-model context-window overrides, keyed by the upstream model
# id. A llama-server in router mode gives each model its own --ctx-size, so a
# single endpoint-wide `context_window` is too coarse — set the size per model
# here. An entry wins over auto-detection (use it when auto-detect can't see
# the value — e.g. behind the bridge before redeploy — or to pin a deliberate
# value). Inline form shown; the sub-table form
# `[endpoints.model_context_windows]` works too (see docs/configuration.md).
# model_context_windows = { "Gemma4-26B" = 40960, "GLM-4.7-Flash" = 65536 }

# Optional: per-model prompt-style + hint for prompt enhancement (see the
# top-level [image_enhancement] block above). Keyed by the upstream model id,
# like model_context_windows. `prompt_style` for an IMAGE model is one of
# natural-language | booru-tags | keyword-soup | hybrid | json; for a VIDEO model
# it's cinematic-prose | structured-cinematic. `prompt_hint` is freeform per-model
# nuance appended to the enhancer instructions (and for `json`, where the exact
# field schema goes — e.g. Ideogram 4). A style from the wrong medium is ignored
# (clarify-only fallback). These win over any prompt_style/prompt_hint the bridge
# advertises in /v1/models. Sub-table form shown.
# [endpoints.model_prompt_styles]
#   "illustrious-xl" = "booru-tags"
#   "flux-2-klein"   = "natural-language"
#   "ideogram-4"     = "json"
#   "ltx-2.3"        = "cinematic-prose"      # video
#   "wan-2.2"        = "structured-cinematic" # video
# [endpoints.model_prompt_hints]
#   "illustrious-xl" = "prefix: masterpiece, best quality, amazing quality; no score_N tags"
#   "z-image-turbo"  = "keep under ~60 words, front-load the subject"
#   "ltx-2.3"        = "generates synchronized audio — end with a brief ambient-sound cue"

# Optional: web search via SearxNG. Backs the `web_search` tool, which
# the assistant calls on its own when a query needs current information.
# When this block is absent, `web_search` is hidden from the model
# entirely — the rest of the app boots normally. `fetch_url` (the paired
# tool that reads a single URL) is always available and does NOT depend
# on this block, so users can paste links for the model to read even
# without a search backend.
#
# Requires a SearxNG instance with the JSON output format enabled. In
# SearxNG's settings.yml: `search.formats: [html, json]`. See the
# README's "Web search" section for setup details.
#
# Capability-named so the section survives a future swap to a different
# search backend (Brave, Tavily, Kagi) — only the implementation
# changes; the [search] block stays.
#
# [search]
# url = "http://192.168.1.10:8888"
# api_key_env = "SEARXNG_API_KEY"   # optional; many SearxNG instances need no auth
# timeout_seconds = 10              # optional; default 10

# Optional: embedding model for hybrid retrieval. When present, the `fetch_url`
# tool ranks the sections of an over-budget page with BM25 + embedding cosine
# (fused via Reciprocal Rank Fusion) and returns the most relevant ones rather
# than just the first ~20 KB. It also adds a semantic leg to the `recall_memory`
# tool: a background worker embeds saved memories so a recall *query* can match
# by meaning, not just keywords. Memory recall itself does NOT need this block —
# once the inlined bodies exceed a size budget the system prompt switches to a
# compact `[id] topic` index regardless, and the model reads bodies back by id
# (pure SQLite) or by BM25 keyword query. When absent, fetch_url falls back to
# BM25-only selection and recall queries to keyword-only, so this block is purely
# an upgrade — omit it freely. See the README's "Web reading & RAG" section.
#
# `endpoint_id` names one of the [[endpoints]] above (base_url + auth are
# inherited from it); `model_id` is the upstream embedding model. A bad
# endpoint_id silently disables embeddings (degrades to BM25) rather than
# erroring at boot.
#
# [embeddings]
# endpoint_id = "nas-bridge"
# model_id = "text-embedding-3-small"
# timeout_seconds = 30            # optional; default 30
# max_input_tokens = 512          # optional; default 512. The model's max input
#                                 # sequence length — each embedded text is
#                                 # truncated to fit (an over-limit input 500s).
#                                 # Raise for large-context models (e.g. 8192).
# query_prefix = ""               # optional; default "". Some models (nomic,
# document_prefix = ""            # e5, bge, gte) need asymmetric task prefixes
#                                 # ("search_query: " / "search_document: ");
#                                 # OpenAI/Cohere-style models must NOT have them.
# gallery_search_min_similarity = 0.5  # optional; default 0.5; range 0–1. Cosine
#                                 # floor for the gallery prompt search's semantic
#                                 # leg — a dense neighbour must score at least this
#                                 # to surface, so genuine synonyms appear but
#                                 # unrelated prompts don't. Model-dependent: raise
#                                 # for tighter matches, lower for more recall.

# Optional: cross-encoder reranker for hybrid retrieval. When present, the
# `fetch_url` tool reorders the top fused candidates (BM25 ⊕ embedding) of an
# over-budget page with a reranker before packing them to the budget — the
# largest quality gain after hybrid retrieval. Purely additive: without this
# block, selection keeps the fused order. A bad endpoint_id, or any failure at
# request time, silently falls back to the fused order (never an error). See the
# README's "Web reading & RAG" section and docs/web-search.md.
#
# Use a PURPOSE-TRAINED cross-encoder, not a chat model: a ~568M bge-reranker
# beats a 7B general LLM at this and is far cheaper. Serve one via llama.cpp
# (--reranking), HF TEI, Infinity, or vLLM.
#
# [rerank]
# endpoint_id = "local-rerank"    # one of the [[endpoints]] above
# model_id = "bge-reranker-v2-m3"
# timeout_seconds = 30            # optional; default 30
# top_n = 20                      # optional; default 20 — how many of the top
#                                 # fused candidates to rerank (cost ceiling).
# quirk = "tei"                   # optional; wire-shape variant. Default speaks
#                                 # the Cohere/Jina shape (vLLM, llama.cpp,
#                                 # Infinity, Jina); set "tei" for Hugging Face
#                                 # Text Embeddings Inference (different request
#                                 # field, response shape, and root path).

# Optional: MCP (Model Context Protocol) servers. Each [[mcp_servers]] block
# defines an external tool server whose advertised tools get registered
# alongside the built-in ones (web_search, fetch_url, memory, clock) and
# become available to every conversation by default. Each server contributes
# a per-conversation toggle category named `mcp:<id>` that gates all of its
# tools in one switch.
#
# Two transports are supported:
#   - "stdio": GlyphStream spawns the server as a subprocess and speaks
#     line-delimited JSON-RPC over its stdin/stdout. The subprocess is
#     reaped after `idle_timeout_seconds` of inactivity (default 900,
#     i.e. 15 minutes) and re-spawned transparently on the next call.
#     Set to 0 to keep the subprocess alive indefinitely.
#   - "http": GlyphStream connects to a Streamable HTTP MCP endpoint.
#     No idle reaping (HTTP keeps no expensive state at rest).
#
# MCP tools default to "ask every time" — the chat pauses with an Allow /
# Allow Always / Reject prompt before the tool runs. "Allow Always" stores
# the tool's namespaced name (mcp__<id>__<tool>) in the user's trusted-tools
# list and bypasses future prompts; revoke from /settings/permissions.
#
# Example: the official filesystem MCP server, scoped to /tmp.
# [[mcp_servers]]
# id = "fs"
# display_name = "Filesystem"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
# timeout_seconds = 30        # optional; default 30
# idle_timeout_seconds = 900  # optional; default 900 — set 0 to disable
#
# # Optional: extra env vars to pass into the subprocess. Each value is the
# # *name* of a GlyphStream-side env var to source from (same convention as
# # *_env fields elsewhere — the secret never lives in this file).
# # env_from = { LINEAR_API_KEY = "LINEAR_API_KEY", DEBUG = "MCP_DEBUG" }
#
# Example: a hosted Streamable HTTP MCP server.
# [[mcp_servers]]
# id = "linear"
# display_name = "Linear"
# transport = "http"
# url = "https://mcp.linear.app/mcp"
# api_key_env = "LINEAR_MCP_KEY"   # optional; sent as Authorization: Bearer
#
# Deferred tool loading ("tool search"). A server with many tools (e.g. the
# GitHub MCP, ~45) sends its full tool schemas on EVERY request — tens of
# thousands of tokens whether or not a turn uses them, which hurts on the
# small-context local models this project targets. Set `defer_tools = true` to
# hide this server's tools from the default tool list; the assistant finds them
# on demand via the built-in `search_tools` tool, and a tool it searches up
# stays loaded for the rest of that conversation. Hybrid search (keyword BM25 +
# semantic, the latter only when an [embeddings] block is configured). Off by
# default; recommended only for high-tool-count servers.
# [[mcp_servers]]
# id = "github"
# display_name = "GitHub"
# transport = "http"
# url = "https://api.githubcopilot.com/mcp/"
# api_key_env = "GITHUB_MCP_KEY"
# defer_tools = true   # optional; default false
#
# Per-user authentication (multi-user). By default a server is `auth =
# "global"`: one shared credential from `api_key_env`, resolved at boot. Set
# `auth = "per_user"` when the token identifies an INDIVIDUAL account (e.g. a
# personal email MCP) — then each user supplies their own token under
# Settings -> MCP servers (stored encrypted, keyed per user), the connection
# is made under their identity, and users without a token simply don't see the
# server's tools. Per-user auth is HTTP-only and must NOT set `api_key_env`
# (the token is per user, not from the environment). Stored credentials are
# encrypted with MCP_SECRET_KEY, which defaults to AUTH_SECRET — so no extra
# setup is needed unless you want to rotate it independently.
# [[mcp_servers]]
# id = "email"
# display_name = "Email"
# transport = "http"
# url = "https://api.fastmail.com/mcp"
# auth = "per_user"
#
# `post_only = true` (HTTP only, default false) tells GlyphStream to skip the
# OPTIONAL MCP server->client GET SSE stream and talk to the server POST-only.
# GlyphStream never consumes server-initiated messages, so this changes nothing
# functionally. Set it for servers whose long-lived GET stream your runtime
# can't drain — Fastmail's MCP is the known case: under some Node/undici + egress
# combinations it routes tool responses INTO that stream, so with it open every
# tool call hangs until the request timeout. POST-only makes responses come back
# on the POST (where they return in ~40ms). If a server's tools mysteriously time
# out while a plain curl to it works, try this.
# post_only = true

# Optional: Web Push notifications for assistant-message completions.
# Generate the keypair once with:  npx web-push generate-vapid-keys
# Put the public key here (plaintext, no secret), the private key in the
# env var named below (never in this file), and a contact mailto: URL
# that push services may use if our pushes misbehave.
#
# Omit the entire [notifications] block to soft-disable push features —
# the app still boots and toasts still work; only Web Push goes quiet.
#
# [notifications]
# vapid_public = "BPI...your-base64url-public-key..."
# vapid_private_env = "VAPID_PRIVATE_KEY"
# vapid_subject = "mailto:admin@example.com"

# Optional: server-side Pyodide code interpreter (the `run_python` tool).
# Pyodide runs in node:worker_threads — one worker per active conversation,
# idle-reaped after `idle_timeout_seconds`, with a wall-clock per-call cap
# and a V8 heap cap per worker. The whole block is optional; omit it to
# accept the defaults shown below, or set `enabled = false` to ship the
# binary without the tool registered.
#
# Python's network access (pyodide.http.pyfetch, urllib, requests,
# micropip) is intercepted by a global fetch shim that applies the same
# SSRF + configured-backend block as the fetch_url tool, AND honors the
# per-conversation `web` feature toggle — disabling `web` for the
# conversation also blocks Python network calls (including micropip),
# so the model can't end-around the toggle via Pyodide.
#
# [code_interpreter]
# enabled = true                  # master switch
# pool_max = 10                   # max concurrent live workers
# idle_timeout_seconds = 300      # 5 min of inactivity → worker reaped
# call_timeout_seconds = 30       # wall-clock per call → terminate on overrun
# worker_memory_mb = 512          # V8 old-space cap per worker
# # pyodide_index_url = ""        # leave empty to resolve from node_modules
