# Keep the build context lean — anything in here is NOT sent to Docker.

# Build artifacts and dependency caches
node_modules
.svelte-kit
build
.pnpm-store
bundle-stats.html

# Local data (the runtime gets a bind-mounted ./data instead)
data

# Editor / OS junk
.git
.gitignore
.github
.vscode
.idea
.DS_Store

# Secrets and local-only configs — never bake into the image
.env
.env.*
!.env.example
config.toml
!config.toml.example

# Misc
*.md
!README.md
LICENSE
