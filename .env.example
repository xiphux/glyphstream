# GlyphStream — environment variables
# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# --- Auth (required) -------------------------------------------------------
# Random 32+ byte hex string for signing session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub OAuth app credentials. Create at:
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL must be: ${EXTERNAL_BASE_URL}/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Comma-separated list of NUMERIC GitHub user IDs allowed to log in.
# Look yours up at: https://api.github.com/users/<your-login>
# Use the numeric `id`, NOT username/email — usernames are reusable, IDs are immutable.
ALLOWED_GITHUB_USER_IDS=

# External origin (no trailing slash) — the URL by which this server is
# reached from outside. Used to build the OAuth callback URL.
# Local dev: http://localhost:5173
# Production: https://glyphstream.example.com
# (Avoid names with the PUBLIC_ prefix — SvelteKit reserves that for
# browser-exposed env vars and filters them from server-side reads.)
EXTERNAL_BASE_URL=http://localhost:5173

# --- Storage ---------------------------------------------------------------
DB_PATH=./data/glyphstream.db
MEDIA_DIR=./data/media

# --- Endpoints config -----------------------------------------------------
CONFIG_PATH=./config.toml

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=info
PORT=3000

# SvelteKit adapter-node request body size limit (in bytes). Defaults to
# 512KB upstream — far too small for image uploads (a JPEG photo can
# easily exceed this even after client-side resize). Set to 25 MiB to
# match GlyphStream's own internal 20 MB upload cap with a little
# headroom for the multipart-form overhead. Use `0` to disable entirely.
BODY_SIZE_LIMIT=26214400

# --- Endpoint API keys (referenced by config.toml `*_env` fields) ---------
# Add one entry per endpoint that needs auth. The variable name must match
# the `api_key_env` value in config.toml.
# NAS_BRIDGE_KEY=
# GROQ_API_KEY=
