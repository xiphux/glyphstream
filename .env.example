# GlyphStream — environment variables
# Copy to .env and fill in. .env is gitignored; .env.example is committed.

# --- Auth (required) -------------------------------------------------------
# Random 32+ byte hex string for signing session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub OAuth app credentials. Create at:
# https://github.com/settings/developers → New OAuth App
# Authorization callback URL must be: ${EXTERNAL_BASE_URL}/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Google OAuth (optional). Create a "Web application" OAuth client at:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${EXTERNAL_BASE_URL}/api/auth/oauth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Generic OIDC (optional). Point at any OpenID Connect issuer — endpoints are
# discovered from ${OIDC_ISSUER}/.well-known/openid-configuration at runtime.
# Redirect URI must be: ${EXTERNAL_BASE_URL}/api/auth/oauth/oidc/callback
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISPLAY_NAME=SSO            # button label (e.g. Authentik, Company SSO)
# OIDC_SCOPES=openid profile email # space-separated; openid is mandatory

# External origin (no trailing slash) — the URL by which this server is
# reached from outside. Used to build the OAuth callback URL AND the
# WebAuthn relying-party ID (the hostname) for passkey logins.
# Local dev: http://localhost:5173
# Production: https://glyphstream.example.com
# (Avoid names with the PUBLIC_ prefix — SvelteKit reserves that for
# browser-exposed env vars and filters them from server-side reads.)
#
# WARNING: changing this value after passkeys have been registered will
# invalidate every existing passkey — the WebAuthn RP ID is derived from
# the hostname and credentials are bound to it.
EXTERNAL_BASE_URL=http://localhost:5173

# Login method toggles. GitHub + passkey default on; Google + OIDC default
# off. An OAuth button only appears when its flag is on AND its credentials
# are set. At least one method must be enabled; the server refuses to boot
# when none are.
# GITHUB_LOGIN_ENABLED=1
# GOOGLE_LOGIN_ENABLED=1
# OIDC_LOGIN_ENABLED=1
# PASSKEY_LOGIN_ENABLED=1

# Optional bootstrap token for the first-run /setup wizard. When unset,
# /setup is openly reachable while no user exists (matches the Jellyfin
# threat model — the race window is small and the payoff is "an account
# on someone else's empty server"). Set to a random value if you're
# deploying to a long-known subdomain and want defense-in-depth; the
# wizard will then require /setup?token=<value>. The token has no
# effect once the first user has been created — /setup is closed
# structurally at that point.
# SETUP_TOKEN=

# Master key for encrypting per-user MCP credentials at rest (AES-256-GCM),
# used by config.toml MCP servers declared `auth = "per_user"`. OPTIONAL —
# defaults to AUTH_SECRET, so per-user MCP needs no extra setup. Set this only
# to rotate MCP-credential encryption independently of session secrets (with
# it set, rotating AUTH_SECRET won't invalidate stored MCP tokens). Generate
# with: openssl rand -hex 32. Treat as durable: rotating whichever key is in
# effect invalidates every stored MCP credential (users re-enter their tokens).
# MCP_SECRET_KEY=

# --- Storage ---------------------------------------------------------------
DB_PATH=./data/glyphstream.db
MEDIA_DIR=./data/media
# Agent-skill bundles (SKILL.md + resources) are stored on disk here, one
# directory per skill (`<user-id>/<skill-name>/`).
SKILLS_DIR=./data/skills

# --- Endpoints config -----------------------------------------------------
CONFIG_PATH=./config.toml

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=info
PORT=3000

# SvelteKit adapter-node request body size limit (in bytes). Defaults to
# 512KB upstream — far too small for image uploads (a JPEG photo can
# easily exceed this even after client-side resize). Set to 25 MiB to
# match GlyphStream's own internal 20 MB upload cap with a little
# headroom for the multipart-form overhead. Use `0` to disable entirely.
BODY_SIZE_LIMIT=26214400

# On-the-fly compression for SSR HTML + API JSON. Default off. Turn on
# when the reverse proxy in front (Synology DSM's built-in proxy is the
# canonical case) can't compress dynamic responses itself. When on,
# picks the best codec the client accepts in priority order zstd > br >
# gzip. SSE (text/event-stream) is always skipped to keep chat streaming
# unbuffered. Static /_app/immutable/* assets are precompressed at build
# time and aren't affected.
# COMPRESS_DYNAMIC=1

# --- Endpoint API keys (referenced by config.toml `*_env` fields) ---------
# Add one entry per endpoint that needs auth. The variable name must match
# the `api_key_env` value in config.toml.
# NAS_BRIDGE_KEY=
# GROQ_API_KEY=
