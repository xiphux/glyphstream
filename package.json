{
	"name": "glyphstream",
	"private": true,
	"version": "0.9.0",
	"type": "module",
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm exec esbuild scripts/import-owui.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=build/scripts/import-owui.js",
		"analyze": "ANALYZE=1 vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"import:owui": "tsx scripts/import-owui.ts"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"arctic": "latest",
		"better-sqlite3": "latest",
		"drizzle-orm": "latest",
		"linkedom": "^0.18.12",
		"markdown-it": "latest",
		"sharp": "^0.34.5",
		"shiki": "latest",
		"smol-toml": "latest",
		"web-push": "^3.6.7"
	},
	"devDependencies": {
		"@lucide/svelte": "^1.16.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "latest",
		"@sveltejs/kit": "^2.61.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "latest",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/better-sqlite3": "latest",
		"@types/markdown-it": "latest",
		"@types/node": "latest",
		"@types/web-push": "^3.6.4",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/ui": "^4.1.7",
		"bits-ui": "latest",
		"drizzle-kit": "latest",
		"esbuild": "^0.28.0",
		"happy-dom": "^20.9.0",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwindcss": "latest",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"workbox-core": "^7.4.1",
		"workbox-precaching": "^7.4.1",
		"workbox-window": "^7.4.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild",
			"sharp"
		]
	}
}
