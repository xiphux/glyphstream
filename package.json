{
	"name": "glyphstream",
	"private": true,
	"version": "0.2.1",
	"type": "module",
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm exec esbuild scripts/import-owui.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outfile=build/scripts/import-owui.js",
		"analyze": "ANALYZE=1 vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"import:owui": "tsx scripts/import-owui.ts"
	},
	"dependencies": {
		"arctic": "latest",
		"better-sqlite3": "latest",
		"drizzle-orm": "latest",
		"markdown-it": "latest",
		"shiki": "latest",
		"smol-toml": "latest"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "latest",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "latest",
		"@types/better-sqlite3": "latest",
		"@types/markdown-it": "latest",
		"@types/node": "latest",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/ui": "^4.1.5",
		"bits-ui": "latest",
		"drizzle-kit": "latest",
		"esbuild": "^0.28.0",
		"jsdom": "^29.1.1",
		"lucide-svelte": "^1.0.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "latest",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.5",
		"workbox-window": "^7.4.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		]
	}
}
