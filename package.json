{
	"name": "glyphstream",
	"private": true,
	"version": "0.30.3",
	"type": "module",
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "pnpm build:worker && vite dev",
		"build": "pnpm build:worker && vite build && pnpm exec esbuild scripts/import-owui.ts --bundle --platform=node --target=node24 --format=esm --packages=external --outfile=build/scripts/import-owui.js && cp src/lib/server/code-interpreter/worker.js build/server/chunks/worker.js",
		"build:worker": "pnpm exec esbuild src/lib/server/code-interpreter/worker.ts --bundle --platform=node --target=node24 --format=esm --external:pyodide --outfile=src/lib/server/code-interpreter/worker.js",
		"analyze": "ANALYZE=1 vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' ; husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"eval": "vitest run --config vitest.eval.config.ts",
		"import:owui": "tsx scripts/import-owui.ts"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,css,md}": "prettier --write"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@mozilla/readability": "^0.6.0",
		"@shikijs/langs": "^4.1.0",
		"@shikijs/themes": "^4.1.0",
		"@shikijs/types": "^4.1.0",
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.1",
		"arctic": "^3.7.0",
		"drizzle-orm": "1.0.0-rc.3",
		"eventsource-parser": "^3.1.0",
		"linkedom": "^0.18.12",
		"markdown-it": "^14.2.0",
		"pyodide": "^0.29.4",
		"sharp": "^0.34.5",
		"shiki": "^4.1.0",
		"smol-toml": "^1.6.1",
		"web-push": "^3.6.7",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@lucide/svelte": "^1.16.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.61.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.9.1",
		"@types/web-push": "^3.6.4",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/ui": "^4.1.7",
		"bits-ui": "^2.18.1",
		"drizzle-kit": "1.0.0-rc.3",
		"esbuild": "^0.28.0",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.6",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.7",
		"workbox-core": "^7.4.1",
		"workbox-precaching": "^7.4.1",
		"workbox-window": "^7.4.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	}
}
